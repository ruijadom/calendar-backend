{
  "name": "calendar-backend",
  "version": "0.1.0",
  "private": true,
  "description": "Fastify + Postgres API for appointments calendar (Railway)",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsx watch src/index.ts",
    "migrate": "node dist/migrate.js",
    "seed": "tsx src/seed/run.ts",
    "seed:dist": "node dist/seed/run.js",
    "db:generate": "drizzle-kit generate",
    "db:studio": "drizzle-kit studio",
    "env:init": "node scripts/init-env.cjs",
    "db:up": "docker compose up -d",
    "db:down": "docker compose down",
    "db:wait": "node scripts/wait-for-db.cjs",
    "db:url": "node scripts/print-db-url.cjs",
    "local:setup": "npm run env:init && npm run db:up && npm run db:wait && npm run build && npm run migrate && npm run seed",
    "local:dev": "npm run dev",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:integration": "CALENDAR_INTEGRATION=1 vitest run src/events.integration.test.ts"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@fastify/cors": "^10.0.1",
    "@fastify/swagger": "^9.7.0",
    "@fastify/swagger-ui": "^5.2.6",
    "dotenv": "^16.4.5",
    "drizzle-orm": "^0.38.3",
    "fastify": "^5.1.0",
    "pg": "^8.13.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^20.17.6",
    "@types/pg": "^8.11.10",
    "drizzle-kit": "^0.30.1",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3",
    "vitest": "^3.1.4"
  }
}
