# Copy to `.env` (never commit `.env`):  npm run env:init
# Or:  cp .env.example .env

# --- Server ---
# Use 3001 locally: Communicator Vite uses 3000 — same port would block the API.
PORT=3001

# Postgres — host port 5433 (see docker-compose.yml; avoids conflict with local :5432)
DATABASE_URL=postgresql://calendar:calendar@localhost:5433/calendar

# Browser origins allowed to call this API (Communicator dev server is :3000 per vite.config)
CORS_ORIGIN=http://localhost:3000

# OpenAPI / Swagger "Try it out" server URL (local)
PUBLIC_API_URL=http://localhost:3001

# Optional: if set, all /api/v1/* require X-API-Key or ?apiKey= (SSE)
# API_KEY=
